---
const navItems = [
  { href: '/#szolgaltatasok', label: 'Szolgáltatások' },
  { href: '/#referenciak', label: 'Referenciák' },
  { href: '/#rolunk', label: 'Rólunk' },
  { href: '/blog/', label: 'Tudásbázis' },
];
const current = Astro.url.pathname;
function isActive(href: string) {
  return href === '/blog/' && current.startsWith('/blog');
}
---

<header id="nav" class="fixed top-0 inset-x-0 z-50 backdrop-blur-md bg-base/70 border-b border-line/70">
  <div class="max-w-8xl mx-auto px-5 lg:px-8 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3">
      <img src="/bimline-logo.png" alt="BIMLine Gépész Kft." class="h-6 w-auto" />
      <span class="hidden sm:inline text-muted font-sans text-xs border-l border-line pl-3">Gépész Kft.</span>
    </a>

    <nav class="hidden lg:flex items-center gap-8 text-sm text-muted font-medium">
      {navItems.map((item) => (
        <a href={item.href} class:list={["hover:text-ink transition", { "text-ink": isActive(item.href) }]}>{item.label}</a>
      ))}
      <a href="/#kapcsolat" class="px-4 py-2 rounded-lg bg-accent text-base font-semibold hover:bg-accent/90 transition glow-accent">Kapcsolat</a>
    </nav>

    <button id="menuBtn" class="lg:hidden p-2 -mr-2 text-ink" aria-label="Menü megnyitása" aria-expanded="false">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>

  <div id="mobileMenu" class="lg:hidden hidden border-t border-line bg-base/95 backdrop-blur-md">
    <nav class="px-5 py-4 flex flex-col gap-1 text-sm">
      {navItems.map((item) => (
        <a href={item.href} class="py-2.5 text-muted hover:text-ink">{item.label}</a>
      ))}
      <a href="/#kapcsolat" class="mt-2 py-2.5 text-center rounded-lg bg-accent text-base font-semibold">Kapcsolat</a>
    </nav>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('menuBtn');
  const mobileMenu = document.getElementById('mobileMenu');
  menuBtn?.addEventListener('click', () => {
    const open = mobileMenu?.classList.toggle('hidden') === false;
    menuBtn.setAttribute('aria-expanded', String(open));
  });
  mobileMenu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => mobileMenu.classList.add('hidden')));
</script>
