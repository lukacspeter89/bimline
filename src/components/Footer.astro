---
import { SITE, getSocialLinks } from '../lib/site';
const socialLinks = getSocialLinks();
const base = import.meta.env.BASE_URL;
const socialIcons: Record<string, string> = {
  linkedin: 'M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8h4V23h-4V8zm7.5 0h3.8v2.05h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V23h-4v-6.9c0-1.65-.03-3.77-2.3-3.77-2.3 0-2.66 1.8-2.66 3.65V23h-4V8z',
  facebook: 'M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.1 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z',
  youtube: 'M23.5 6.2a3 3 0 0 0-2.1-2.1C19.4 3.5 12 3.5 12 3.5s-7.4 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c2 .6 9.4.6 9.4.6s7.4 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.6 15.6V8.4l6.3 3.6-6.3 3.6z',
  instagram: 'M12 2.2c3.2 0 3.6 0 4.9.07 3.3.15 4.8 1.7 4.95 4.95.06 1.3.07 1.7.07 4.9s0 3.6-.07 4.9c-.15 3.24-1.66 4.8-4.95 4.95-1.3.06-1.7.07-4.9.07s-3.6 0-4.9-.07c-3.3-.15-4.8-1.7-4.95-4.95C2.08 15.6 2.07 15.2 2.07 12s0-3.6.07-4.9C2.29 3.87 3.8 2.32 7.1 2.17 8.4 2.11 8.8 2.1 12 2.1zM12 0C8.7 0 8.3 0 7 .07c-4.4.2-6.78 2.6-7 7C0 8.3 0 8.7 0 12s0 3.7.07 5c.2 4.4 2.6 6.78 7 7C8.3 24 8.7 24 12 24s3.7 0 5-.07c4.4-.2 6.8-2.6 7-7C24 15.7 24 15.3 24 12s0-3.7-.07-5c-.2-4.4-2.6-6.8-7-7C15.7 0 15.3 0 12 0zm0 5.8A6.2 6.2 0 1 0 12 18.2 6.2 6.2 0 0 0 12 5.8zm0 10.2A4 4 0 1 1 12 8a4 4 0 0 1 0 8zm6.4-10.4a1.44 1.44 0 1 1 0-2.88 1.44 1.44 0 0 1 0 2.88z',
};
---

<footer class="border-t border-line bg-surface/60 mt-24 lg:w-3/4 lg:mx-auto">
  <div class="max-w-8xl mx-auto px-5 lg:px-8 py-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
    <div>
      <a href={base} class="flex items-center gap-3">
        <img src={`${base}bimline-logo.png`} alt={SITE.name} class="h-6 w-auto" />
      </a>
      <p class="text-sm text-muted mt-4 leading-relaxed">{SITE.description}</p>
    </div>

    <div>
      <p class="eyebrow mb-3">Oldal</p>
      <ul class="space-y-2 text-sm text-muted">
        <li><a href={`${base}#szolgaltatasok`} class="hover:text-ink">Szolgáltatások</a></li>
        <li><a href={`${base}#referenciak`} class="hover:text-ink">Referenciák</a></li>
        <li><a href={`${base}#rolunk`} class="hover:text-ink">Rólunk</a></li>
        <li><a href={`${base}#kapcsolat`} class="hover:text-ink">Kapcsolat</a></li>
        <li><a href={`${base}adatkezeles/`} class="hover:text-ink">Adatkezelés</a></li>
      </ul>
    </div>

    <div>
      <p class="eyebrow mb-3">Tudásbázis</p>
      <ul class="space-y-2 text-sm text-muted">
        <li><a href={`${base}blog/`} class="hover:text-ink">Blog / szakmai cikkek</a></li>
        <li><a href={`${base}rss.xml`} class="hover:text-ink">RSS feed</a></li>
      </ul>
    </div>

    <div>
      <p class="eyebrow mb-3">Elérhetőség</p>
      <ul class="space-y-2 text-sm text-muted">
        <li><a href={`mailto:${SITE.email}`} class="hover:text-ink">{SITE.email}</a></li>
        <li>{SITE.address.postalCode} {SITE.address.addressLocality}, {SITE.address.streetAddress}</li>
      </ul>
      <!-- Közösségi média helyek előkészítve — amint elkészülnek a profilok,
           a src/lib/site.ts fájlban a `social` objektumba kell beírni az URL-eket,
           és itt (és a JSON-LD sameAs mezőben) automatikusan megjelennek. -->
      <div class="flex gap-3 mt-4">
        {(['linkedin', 'facebook', 'youtube', 'instagram'] as const).map((platform) => {
          const link = socialLinks.find((s) => s.platform === platform);
          return (
            <a
              href={link?.url || '#'}
              aria-label={platform}
              class:list={["w-8 h-8 rounded-lg bg-surface2 border border-line grid place-items-center transition", link ? "hover:border-accent/60 hover:text-accent text-muted" : "opacity-30 pointer-events-none text-muted"]}
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d={socialIcons[platform]} /></svg>
            </a>
          );
        })}
      </div>
    </div>
  </div>
  <div class="max-w-8xl mx-auto px-5 lg:px-8 pb-8 flex flex-col sm:flex-row sm:items-center justify-between gap-3 text-xs text-muted/70 border-t border-line/50 pt-6">
    <p>© {new Date().getFullYear()} {SITE.name} Minden jog fenntartva.</p>
    <div class="flex items-center gap-4">
      <a href={`${base}adatkezeles/`} class="hover:text-muted">Adatkezelési tájékoztató</a>
      <button type="button" id="footerCookiePrefsBtn" class="hover:text-muted underline underline-offset-2">Süti beállítások</button>
    </div>
  </div>
</footer>

<script>
  document.getElementById('footerCookiePrefsBtn')?.addEventListener('click', () => {
    (window as unknown as { bimlineOpenCookiePreferences?: () => void }).bimlineOpenCookiePreferences?.();
  });
</script>
