---
interface Props {
  variant?: 'ajanlat' | 'konzultacio' | 'kapcsolat';
  title?: string;
  description?: string;
}
const {
  variant = 'ajanlat',
  title,
  description,
} = Astro.props;

const presets = {
  ajanlat: {
    title: 'Kérj ajánlatot a projektedre',
    description: 'Írd le röviden a feladatot — 1 munkanapon belül válaszolunk, és megmondjuk, hogyan tudunk segíteni.',
    cta: 'Ajánlatkérés',
  },
  konzultacio: {
    title: 'Bizonytalan vagy, hogy mire van szükséged?',
    description: 'Kérj ingyenes, kötelezettségmentes konzultációt — átbeszéljük a projekt kereteit, és javaslatot teszünk a megfelelő megoldásra.',
    cta: 'Ingyenes konzultáció kérése',
  },
  kapcsolat: {
    title: 'Vedd fel velünk a kapcsolatot',
    description: 'Kérdésed van a szolgáltatásainkkal kapcsolatban? Írj nekünk, örömmel válaszolunk.',
    cta: 'Kapcsolatfelvétel',
  },
};

const preset = presets[variant];
const base = import.meta.env.BASE_URL;
---

<section class="py-14 lg:py-20 bg-surface/40 border-y border-line/60">
  <div class="max-w-3xl mx-auto px-5 lg:px-8 text-center" data-reveal>
    <h2 class="font-display font-bold text-[clamp(1.4rem,2.6vw,1.85rem)] leading-tight">{title || preset.title}</h2>
    <p class="mt-4 text-muted leading-relaxed">{description || preset.description}</p>
    <a href={`${base}#kapcsolat`} class="mt-8 inline-block px-6 py-3 rounded-xl bg-accent text-base font-semibold hover:bg-accent/90 transition glow-accent">{preset.cta}</a>
  </div>
</section>
