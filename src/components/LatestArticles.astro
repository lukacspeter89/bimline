---
import { getCollection } from 'astro:content';
import { estimateReadingTime } from '../lib/reading-time';

interface Props {
  lang?: 'hu' | 'en';
}
const { lang = 'hu' } = Astro.props;

const posts = (await getCollection(lang === 'en' ? 'blogEn' : 'blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
const base = import.meta.env.BASE_URL;
const blogHref = `${base}${lang === 'en' ? 'en/blog/' : 'blog/'}`;

const t = lang === 'en'
  ? { eyebrow: 'Knowledge Base', heading: 'Our latest articles', intro: 'Professional writing on MEP engineering, BIM design and energy audits.', allArticles: 'All articles →', minSuffix: 'min read', locale: 'en-US' }
  : { eyebrow: 'Tudásbázis', heading: 'Legfrissebb cikkeink', intro: 'Szakmai írások épületgépészetről, BIM-tervezésről és energetikai felülvizsgálatról.', allArticles: 'Összes cikk →', minSuffix: 'perc', locale: 'hu-HU' };
---

{posts.length > 0 && (
  <section id="tudasbazis" class="py-16 lg:py-24 border-t border-line/60">
    <div class="max-w-8xl mx-auto px-5 lg:px-8">
      <div class="flex flex-wrap items-end justify-between gap-4 mb-10" data-reveal>
        <div class="max-w-2xl">
          <p class="eyebrow mb-3">{t.eyebrow}</p>
          <h2 class="font-display font-bold text-[clamp(1.4rem,2.6vw,1.85rem)] leading-tight">{t.heading}</h2>
          <p class="mt-3 text-muted">{t.intro}</p>
        </div>
        <a href={blogHref} class="text-sm text-accent hover:text-belimo font-semibold whitespace-nowrap">{t.allArticles}</a>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <a href={`${blogHref}${post.id}/`} class="card rounded-xl overflow-hidden flex flex-col" data-reveal>
            {post.data.coverImage && (
              <div class="aspect-[16/9] overflow-hidden">
                <img src={post.data.coverImage.src} alt="" class="w-full h-full object-cover" loading="lazy" />
              </div>
            )}
            <div class="p-5 flex flex-col flex-1">
              <div class="flex items-center gap-2 text-xs font-display tracking-wide mb-2 text-muted">
                <span class="text-accent font-semibold">{post.data.category}</span>
                <span>·</span>
                <span>{post.data.publishDate.toLocaleDateString(t.locale)}</span>
                <span>·</span>
                <span>{estimateReadingTime(post.body || '')} {t.minSuffix}</span>
              </div>
              <h3 class="font-display font-semibold text-lg leading-snug">{post.data.title}</h3>
              <p class="text-sm text-muted mt-2 leading-relaxed flex-1">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
